# Copy to `.env`. Vite reads VITE_* at build time (and in dev via loadEnv).







# ---- App (Vite) — see src/config/appConfig.ts ----



VITE_BASE_PATH=/



VITE_TITLE=ZetaRe



# VITE_DEV_SERVER_PORT=3000



# VITE_COMPANY_NAME=



# VITE_SUPPORT_EMAIL=



# VITE_VERSION=1.0.0



# VITE_MANIFEST_DESCRIPTION=



# VITE_ENVIRONMENT=development



# VITE_MIXPANEL_TOKEN=







# ---- Supabase (browser) — Project Settings → API ----



VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co



VITE_SUPABASE_ANON_KEY=







# ---- Authentik / OIDC (Vite) — oidc-client-ts + react-oidc-context ----

# Issuer, client id, redirect: must match the Authentik app (and `/auth/callback` route in this repo).

# Confidential token exchange runs on the separate OIDC BFF (not in this repo). The SPA will call the BFF with
# the auth code; `client_secret` never lives in VITE_*.

# VITE_OIDC_ISSUER=



# VITE_OIDC_CLIENT_ID=



# VITE_OIDC_REDIRECT_URI=http://127.0.0.1:3000/auth/callback

# BFF base URL (no trailing slash) — e.g. https://oidc-bff.flordearagua.com

# VITE_OIDC_BFF_URL=



# Optional. Only if the BFF `app.yaml` defines more than one client. Must match a `clients` key in the BFF.

# VITE_OIDC_BFF_CLIENT_KEY=spa-main



# Optional: defaults to "openid email profile zeta_collector" if unset



# VITE_OIDC_SCOPE=openid email profile zeta_collector



# Logout clears only this SPA session (no IdP end-session / SSO logout).





