# Copy to `.env`. Vite reads VITE_* at build time (and in dev via loadEnv).

# ---- App (Vite) — see src/config/appConfig.ts ----
VITE_BASE_PATH=/
VITE_TITLE=ZetaRe
# VITE_DEV_SERVER_PORT=3000
# VITE_COMPANY_NAME=
# VITE_SUPPORT_EMAIL=
# VITE_VERSION=1.0.0
# VITE_MANIFEST_DESCRIPTION=
# VITE_ENVIRONMENT=development
# VITE_MIXPANEL_TOKEN=

# ---- Supabase (browser) — Project Settings → API ----
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# ---- Authentik / OIDC (browser) — public client; tokens live in the SPA after login ----
# Option A: full login URL (e.g. created in Authentik for this app)
# VITE_OIDC_LOGIN_URL=
# Option B: build /application/o/authorize from these
# VITE_OIDC_ISSUER=https://authentik.example.com
# VITE_OIDC_CLIENT_ID=
# VITE_OIDC_REDIRECT_URI=http://127.0.0.1:3000/auth/oauth-bridge
# VITE_OIDC_END_SESSION_URL=
